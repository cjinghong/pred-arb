# ═══════════════════════════════════════════════════════════════
# PRED-ARB — Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── Platforms ────────────────────────────────────────────────
# Which platforms to connect. At least 2 required for arbitrage.
# Options: polymarket, predictfun, kalshi
ENABLED_PLATFORMS=polymarket,kalshi

# ─── Polymarket ───────────────────────────────────────────────
# L2 API credentials (preferred) — get from Polymarket CLOB API docs
# If not set, falls back to L1 auth using your private key
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
# Ethereum wallet private key (hex, no 0x prefix)
POLYMARKET_PRIVATE_KEY=
# Proxy wallet address — find on your Polymarket profile page
POLYMARKET_PROXY_ADDRESS=

# ─── Kalshi ───────────────────────────────────────────────────
# API key ID from Kalshi → Settings → API Keys
KALSHI_API_KEY_ID=
# RSA-4096 private key. Two options:
#   1. Inline PEM: paste the key with literal \n for newlines
#   2. File path: set KALSHI_PRIVATE_KEY_PATH instead
# Generate: openssl genrsa -out kalshi-key.pem 4096
# Upload the PUBLIC key to Kalshi API settings
KALSHI_PRIVATE_KEY=
KALSHI_PRIVATE_KEY_PATH=
# Set to true for demo/sandbox API (paper trading)
KALSHI_USE_DEMO=false

# ─── predict.fun (optional) ──────────────────────────────────
# Add 'predictfun' to ENABLED_PLATFORMS to activate
PREDICTFUN_API_KEY=
PREDICTFUN_PRIVATE_KEY=
PREDICTFUN_SMART_WALLET=
PREDICTFUN_USE_TESTNET=false

# ─── Bot Settings ────────────────────────────────────────────
# IMPORTANT: DRY_RUN=true means no real trades. Set to false for live trading.
DRY_RUN=true
# Minimum profit to execute (basis points). 150 = 1.5%
MIN_PROFIT_BPS=150
# Max USD per trade leg
MAX_POSITION_USD=500
# Max total USD exposure across all positions
MAX_TOTAL_EXPOSURE_USD=5000
# Min orderbook depth (USD) to consider an opportunity. 0 = no minimum.
MIN_DEPTH_USD=50

# ─── Market Discovery ───────────────────────────────────────
# Categories to scan (comma-separated). Each is fetched and matched independently.
# Options: sports, politics, crypto, esports, finance, culture
# Sub-categories: basketball, football, soccer, baseball, hockey, mma, tennis, golf, etc.
MARKET_CATEGORIES=sports,politics

# ─── LLM (for market matching) ──────────────────────────────
# Used to match equivalent markets across platforms.
# Sports markets use deterministic matching (no LLM needed).
# Non-sports (politics, crypto) need an LLM for fuzzy matching.
#
# Option 1: Ollama (free, local) — recommended for getting started
#   Install: https://ollama.com → ollama pull llama3.1
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1
#
# Option 2: Anthropic API
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
#
# Option 3: Any OpenAI-compatible API
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_MODEL=your-model
# LLM_API_KEY=your-key
