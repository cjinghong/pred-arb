# ─── Polymarket ───────────────────────────────────────────
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=
# Proxy wallet address — find on your Polymarket profile page
# Required: your funds live in this proxy, not your EOA
POLYMARKET_PROXY_ADDRESS=

# ─── predict.fun ──────────────────────────────────────────
# Get an API key from the predict.fun Discord (mainnet only; testnet is open)
PREDICTFUN_API_KEY=
# Privy wallet private key — find in predict.fun account settings
PREDICTFUN_PRIVATE_KEY=
# Smart Wallet (Predict Account) address — used for signing, auth, and balance checks
# Find at predict.fun account settings or on bscscan
PREDICTFUN_SMART_WALLET=
# Set to true to use the testnet (no API key required)
PREDICTFUN_USE_TESTNET=false

# ─── Kalshi ──────────────────────────────────────────────
# API key ID — from Kalshi account settings → API Keys
KALSHI_API_KEY_ID=
# RSA private key — either inline PEM (with \n escaped) or path to PEM file
# Generate: openssl genrsa -out kalshi-key.pem 4096
# Then upload the public key to Kalshi API settings
KALSHI_PRIVATE_KEY=
KALSHI_PRIVATE_KEY_PATH=
# Set to true to use Kalshi demo/sandbox API
KALSHI_USE_DEMO=false

# ─── Bot Configuration ────────────────────────────────────
# Dry-run mode: set to 'false' to enable REAL trading. Default: true (safe).
DRY_RUN=true
# Minimum profit threshold in basis points (100 = 1%). Use negative for testing.
MIN_PROFIT_BPS=150
# Maximum position size in USD
MAX_POSITION_USD=500
# Scan interval in milliseconds (used as fallback; primary scanning is WS-driven)
SCAN_INTERVAL_MS=10000
# Maximum total exposure in USD
MAX_TOTAL_EXPOSURE_USD=5000
# Minimum order book depth (USD) to consider an opportunity. Set to 0 for testing.
MIN_DEPTH_USD=50
# Interval for refreshing market pairs (ms). Default: 5 minutes.
PAIR_REFRESH_INTERVAL_MS=300000
# Market category filter. Restricts to a specific category for better match rates.
# Options: '' (all markets), 'sports', 'basketball', 'football', 'soccer',
#   'baseball', 'hockey', 'mma', 'tennis', 'golf', 'motorsports', 'nba', 'nfl', etc.
# When set, all platforms paginate to fetch ALL markets in that category.
MARKET_CATEGORY=

# ─── Dashboard ────────────────────────────────────────────
DASHBOARD_PORT=3847
API_PORT=3848

# ─── Database ─────────────────────────────────────────────
DB_PATH=./data/pred-arb.db

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=info

# ─── Anthropic API Key ──────────────────────────────────────
ANTHROPIC_API_KEY=