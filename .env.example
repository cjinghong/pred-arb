MAX_POSITION_USD=500
# Scan interval in milliseconds
SCAN_INTERVAL_MS=10000
# Maximum total exposure in USD
MAX_TOTAL_EXPOSURE_USD=5000

# ─── Dashboard ────────────────────────────────────────────
DASHBOARD_PORT=3847
API_PORT=3848

# ─── Database ─────────────────────────────────────────────
DB_PATH=./data/pred-arb.db

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=info
