{
  "name": "pred-arb",
  "version": "1.0.0",
  "description": "Prediction market arbitrage bot with extensible connectors and strategies",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc",
    "build:dashboard": "cd dashboard && npm run build",
    "build:all": "npm run build && npm run build:dashboard",
    "dev": "tsx watch src/index.ts",
    "start": "node build/index.js",
    "start:dev": "tsx src/index.ts",
    "dashboard:dev": "cd dashboard && npm run dev",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "backtest": "tsx src/backtest/run-backtest.ts",
    "typecheck": "tsc --noEmit",
    "setup": "npm install && cd dashboard && npm install"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "ethers": "^6.11.0",
    "express": "^4.18.2",
    "fuse.js": "^7.0.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
